# ============================================
# SparkWeave 环境变量模板（中文）
# ============================================
# 复制为 `.env` 后填写。
# 当前建议按以下分组配置：
# ports / llm / embedding / search / docker-cloud / security

# --------------------------------------------
# 端口
# --------------------------------------------
BACKEND_PORT=8001
FRONTEND_PORT=3782

# --------------------------------------------
# 供应商共享凭据（推荐）
# --------------------------------------------
# 同一家供应商只填一套密钥，设置页会自动共享给问答、Embedding、搜索、OCR、TTS 等能力。
# 科大讯飞：APPID / APIKey / APISecret 三件套；APIPassword 可选，留空时自动使用 APIKey:APISecret。
IFLYTEK_APPID=
IFLYTEK_API_KEY=
IFLYTEK_API_SECRET=
IFLYTEK_API_PASSWORD=
# 讯飞 MaaS Coding / Astron Code 的 APIPassword，通常形如 APIKey:APISecret。
IFLYTEK_MAAS_API_PASSWORD=
# 硅基流动：只需要一套 APIKey，LLM / Embedding / DeepSeek-OCR 共用。
SILICONFLOW_API_KEY=

# --------------------------------------------
# LLM（必填）
# --------------------------------------------
# 支持的 binding: openai, iflytek_spark_ws, iflytek_maas_coding, deepseek, gemini, dashscope, zhipu,
# moonshot, anthropic, siliconflow, lm_studio, ollama, azure_openai, ...
# 最新预设可在网页 `/settings/models` 自助选择；也可以直接填写供应商新发布的模型 ID。
LLM_BINDING=openai
LLM_MODEL=gpt-5.4-mini
LLM_API_KEY=sk-xxx
LLM_HOST=https://api.openai.com/v1
LLM_API_VERSION=
LLM_CONNECT_TIMEOUT=10
LLM_REQUEST_TIMEOUT=900

# 科大讯飞星火 X2 / X1.5 使用 OpenAI 兼容 HTTP 协议。
# 两个版本的模型名均为 spark-x，通过 LLM_HOST 区分版本。
# LLM_BINDING=iflytek_spark_ws
# LLM_MODEL=spark-x
# LLM_HOST=https://spark-api-open.xf-yun.com/x2/
# LLM_API_KEY 可留空，优先使用上方 IFLYTEK_* 共享凭据。
# 可选：
#   X2:   LLM_MODEL=spark-x  LLM_HOST=https://spark-api-open.xf-yun.com/x2/
#   X1.5: LLM_MODEL=spark-x  LLM_HOST=https://spark-api-open.xf-yun.com/v2/
# 讯飞 MaaS Coding / Astron Code 使用 OpenAI 兼容接口：
# LLM_BINDING=iflytek_maas_coding
# LLM_MODEL=astron-code-latest
# LLM_HOST=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
# LLM_API_KEY 可填写 MaaS APIPassword；也可留空并填写 IFLYTEK_MAAS_API_PASSWORD。
# 如需 Anthropic-compatible 入口，可在自定义供应商中使用：
# https://maas-coding-api.cn-huabei-1.xf-yun.com/anthropic
# 其他常用模型示例：
#   OpenAI:     gpt-5.5, gpt-5.4, gpt-5.4-mini, gpt-5.4-nano
#   DeepSeek:   deepseek-v4-flash, deepseek-v4-pro
#   Gemini:     gemini-3.5-flash, gemini-3.1-pro-preview
#   DashScope:  qwen3.6-plus, qwen3.6-flash, qwen3.6-max-preview
#   Zhipu AI:   glm-5.1, glm-5-turbo
#   Moonshot:   kimi-k2.5, kimi-k2-thinking

# --------------------------------------------
# Embedding（知识库能力必填）
# --------------------------------------------
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_HOST=https://api.openai.com/v1
EMBEDDING_DIMENSION=3072
EMBEDDING_API_VERSION=

# --------------------------------------------
# RAG vector database (Milvus)
# --------------------------------------------
# New knowledge bases use Milvus by default.
RAG_PROVIDER=milvus
# Knowledge-base indexing runs in a dedicated background worker pool so uploads
# do not block chat/settings/profile APIs. Keep 1 unless the machine has spare
# CPU/network capacity and the embedding provider allows parallel requests.
SPARKWEAVE_KB_BACKGROUND_WORKERS=1
# Native backend on Windows: start Milvus Standalone with Docker and use localhost.
# docker compose: SparkWeave connects to the Milvus service name via DOCKER_MILVUS_URI.
# Linux/macOS/WSL can alternatively use Milvus Lite: ./data/milvus/sparkweave.db
MILVUS_URI=http://localhost:19530
DOCKER_MILVUS_URI=http://milvus:19530
# MILVUS_URI=./data/milvus/sparkweave.db
MILVUS_TOKEN=
MILVUS_COLLECTION_PREFIX=sparkweave
MILVUS_SIMILARITY_METRIC=IP
MILVUS_CONSISTENCY_LEVEL=Strong
# Set to 0 only if you intentionally want to append into an existing collection.
MILVUS_OVERWRITE_ON_INIT=1
# Retrieval controls for larger KBs. Leave RAG_SCORE_THRESHOLD empty unless you have calibrated scores.
RAG_TOP_K=5
RAG_CANDIDATE_TOP_K=20
RAG_SCORE_THRESHOLD=
RAG_MAX_CONTEXT_CHARS=8000
RAG_RERANKER=none
RAG_RERANK_TOP_N=5
RAG_RERANK_VECTOR_WEIGHT=0.65
RAG_RERANK_LEXICAL_WEIGHT=0.35
# Retrieval mode. Keep dense as the stable default. Set hybrid before indexing a KB to enable Milvus sparse/BM25 fields.
RAG_RETRIEVAL_MODE=dense
# Agentic RAG. Keep global mode off; UI/API can opt in per request.
RAG_AGENTIC_MODE=off
RAG_AGENTIC_MAX_SUBQUERIES=3
RAG_AGENTIC_TIMEOUT_SECONDS=8
RAG_AGENTIC_MAX_CONCURRENCY=3
RAG_AGENTIC_MAX_REPAIR_BRANCHES=3
RAG_AGENTIC_MAX_CONTEXT_CHARS=
RAG_AGENTIC_MAX_SOURCES=
RAG_AGENTIC_FALLBACK_TO_SINGLE=true
RAG_AGENTIC_MIN_QUERY_CHARS=80
RAG_AGENTIC_MIN_SOURCES=1
RAG_AGENTIC_MIN_COVERAGE_RATIO=0.5
RAG_AGENTIC_MIN_RELEVANT_COVERAGE_RATIO=0.67
RAG_AGENTIC_MIN_CONTEXT_CHARS=120
RAG_AGENTIC_MIN_SCORE=
# Hybrid mode controls. Changing these for an existing dense-only KB requires reindexing that KB.
MILVUS_HYBRID_RANKER=RRFRanker
MILVUS_HYBRID_RRF_K=60
MILVUS_DENSE_WEIGHT=1.0
MILVUS_SPARSE_WEIGHT=0.6
# Compatibility fallback for old local indexes:
# RAG_PROVIDER=llamaindex

# 科大讯飞 llm Embedding（可选）
# 文档：https://www.xfyun.cn/doc/spark/Embedding_api.html
# 需要 APPID + APIKey + APISecret，固定返回 2560 维向量。
# 注意：Embedding 也使用 APPID + APIKey + APISecret 三项。
# EMBEDDING_BINDING=iflytek_spark
# EMBEDDING_MODEL=llm-embedding
# EMBEDDING_API_KEY 可留空，优先使用上方 IFLYTEK_API_KEY。
# EMBEDDING_HOST=https://emb-cn-huabei-1.xf-yun.com/
# EMBEDDING_DIMENSION=2560
# IFLYTEK_EMBEDDING_APPID / IFLYTEK_EMBEDDING_API_KEY / IFLYTEK_EMBEDDING_API_SECRET 为旧兼容项，
# 新配置推荐只填写上方 IFLYTEK_APPID / IFLYTEK_API_KEY / IFLYTEK_API_SECRET。

# ⚠️  Docker + 本地模型（LM Studio / Ollama / vLLM）
# ─────────────────────────────────────────────────────
# 当 SparkWeave 以 Docker 方式运行、而 LLM 运行在宿主机上时：
#   - 不要使用 "localhost" 或 "127.0.0.1"——容器内这些地址指向容器自身，
#     而不是宿主机。
#   - macOS / Windows (Docker Desktop): 使用 http://host.docker.internal:<端口>/v1
#   - Linux: 使用宿主机的局域网 IP，例如 http://192.168.1.100:<端口>/v1
#     （或使用 --network=host 模式启动 Docker）
#
# 示例（LM Studio 运行在 1234 端口）:
#   LLM_BINDING=lm_studio
#   LLM_HOST=http://host.docker.internal:1234/v1
#   EMBEDDING_BINDING=lm_studio
#   EMBEDDING_HOST=http://host.docker.internal:1234/v1

# --------------------------------------------
# 搜索（可选）
# --------------------------------------------
SEARCH_PROVIDER=
SEARCH_API_KEY=
SEARCH_BASE_URL=

# 科大讯飞 ONE SEARCH（可选）
# 文档：https://www.xfyun.cn/doc/spark/Search_API/search_API.html
# 搜索 API 使用 APIPassword，写入 SEARCH_API_KEY 或 IFLYTEK_SEARCH_API_PASSWORD 均可。
# 新配置推荐只填写上方 IFLYTEK_API_PASSWORD，或填写 IFLYTEK_API_KEY + IFLYTEK_API_SECRET 自动拼接。
# SEARCH_PROVIDER=iflytek_spark
# SEARCH_BASE_URL=https://search-api-open.cn-huabei-1.xf-yun.com/v2/search
# IFLYTEK_SEARCH_API_PASSWORD=your-iflytek-search-apipassword


# --------------------------------------------
# Docker / 云部署（可选）
# --------------------------------------------
# 前端在远程部署时访问后端的公网地址
NEXT_PUBLIC_API_BASE_EXTERNAL=
# 备用 API 基础地址
NEXT_PUBLIC_API_BASE=

# --------------------------------------------
# 数学动画（可选）
# --------------------------------------------
# 默认只使用后端当前 Python 环境。若必须跨环境调用 Manim，可显式指定可用解释器。
# 示例：C:\Users\hjk\anaconda3\envs\sparkweave\python.exe
SPARKWEAVE_MANIM_PYTHON=
SPARKWEAVE_MATH_ANIMATOR_REPAIR_TIMEOUT=300
SPARKWEAVE_MATH_ANIMATOR_RENDER_TIMEOUT=900

# --------------------------------------------
# OCR / 扫描版 PDF（可选）
# --------------------------------------------
# 设为 iflytek_first 时，知识库 PDF 会优先用科大讯飞 OCR；
# 如果 OCR 不可用、超时或返回为空，会自动回退到默认 PyMuPDF 文本层解析。
# 设为 auto 时，默认先用 PyMuPDF，文本过少时再尝试 OCR。
SPARKWEAVE_OCR_PROVIDER=iflytek
SPARKWEAVE_PDF_OCR_STRATEGY=iflytek_first
SPARKWEAVE_OCR_TIMEOUT=90
SPARKWEAVE_OCR_MAX_PAGES=
SPARKWEAVE_OCR_DPI=200
SPARKWEAVE_OCR_MIN_TEXT_CHARS=40
IFLYTEK_OCR_APPID=
IFLYTEK_OCR_API_KEY=
IFLYTEK_OCR_API_SECRET=
# 上面三个 IFLYTEK_OCR_* 为旧兼容项；新配置推荐只填写共享 IFLYTEK_*。
IFLYTEK_OCR_URL=https://cbm01.cn-huabei-1.xf-yun.com/v1/private/se75ocrbm
IFLYTEK_OCR_SERVICE_ID=se75ocrbm
IFLYTEK_OCR_CATEGORY=ch_en_public_cloud
# 硅基流动 DeepSeek-OCR（可选）：把 SPARKWEAVE_OCR_PROVIDER 改为 siliconflow 后生效。
# 知识库扫描版 PDF 推荐使用 SPARKWEAVE_PDF_OCR_STRATEGY=ocr_first。
SILICONFLOW_OCR_API_KEY=
# 新配置推荐只填写共享 SILICONFLOW_API_KEY。
SILICONFLOW_OCR_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_OCR_MODEL=deepseek-ai/DeepSeek-OCR
SILICONFLOW_OCR_PROMPT=<image>\n<|grounding|>Convert the document to markdown.
SILICONFLOW_OCR_MAX_TOKENS=8192

# --------------------------------------------
# TTS / 多模态语音讲解（可选）
# --------------------------------------------
# 讯飞超拟人语音合成 WebSocket：
# 文档：https://www.xfyun.cn/doc/spark/super%20smart-tts.html
SPARKWEAVE_TTS_PROVIDER=iflytek
SPARKWEAVE_TTS_TIMEOUT=30
IFLYTEK_TTS_APPID=
IFLYTEK_TTS_API_KEY=
IFLYTEK_TTS_API_SECRET=
# 上面三个 IFLYTEK_TTS_* 为旧兼容项；新配置推荐只填写共享 IFLYTEK_*。
IFLYTEK_TTS_URL=wss://cbm01.cn-huabei-1.xf-yun.com/v1/private/mcd9m97e6
IFLYTEK_TTS_VOICE=x5_lingxiaoxuan_flow
IFLYTEK_TTS_ENCODING=lame
IFLYTEK_TTS_SAMPLE_RATE=24000
IFLYTEK_TTS_CHANNELS=1
IFLYTEK_TTS_BIT_DEPTH=16
IFLYTEK_TTS_FRAME_SIZE=0
IFLYTEK_TTS_SPEED=50
IFLYTEK_TTS_VOLUME=50
IFLYTEK_TTS_PITCH=50

# --------------------------------------------
# ASR / 口语评测（可选，科大讯飞）
# --------------------------------------------
# 语音听写用于聊天语音输入、课堂录音转写。
# 文档：https://www.xfyun.cn/doc/asr/voicedictation/API.html
SPARKWEAVE_ASR_PROVIDER=iflytek
SPARKWEAVE_ASR_TIMEOUT=60
IFLYTEK_ASR_APPID=
IFLYTEK_ASR_API_KEY=
IFLYTEK_ASR_API_SECRET=
# 上面三个 IFLYTEK_ASR_* 为旧兼容项；新配置推荐只填写共享 IFLYTEK_*。
IFLYTEK_ASR_URL=wss://iat-api.xfyun.cn/v2/iat
IFLYTEK_ASR_LANGUAGE=zh_cn
IFLYTEK_ASR_ACCENT=mandarin
IFLYTEK_ASR_DOMAIN=iat
IFLYTEK_ASR_VAD_EOS=3000

# 语音评测用于口语跟读、表达训练和学习效果证据闭环。
# 文档：https://www.xfyun.cn/doc/Ise/IseAPI.html
SPARKWEAVE_SPEECH_EVAL_PROVIDER=iflytek
SPARKWEAVE_SPEECH_EVAL_TIMEOUT=60
IFLYTEK_SPEECH_EVAL_APPID=
IFLYTEK_SPEECH_EVAL_API_KEY=
IFLYTEK_SPEECH_EVAL_API_SECRET=
# 上面三个 IFLYTEK_SPEECH_EVAL_* 为旧兼容项；新配置推荐只填写共享 IFLYTEK_*。
IFLYTEK_SPEECH_EVAL_URL=wss://ise-api.xfyun.cn/v2/open-ise
IFLYTEK_SPEECH_EVAL_CATEGORY=read_sentence
IFLYTEK_SPEECH_EVAL_LANGUAGE=zh_cn

# --------------------------------------------
# 讯飞公式识别（可选，数学/工科题图）
# --------------------------------------------
# 文档：https://www.xfyun.cn/doc/words/formula-discern/API.html
# 可复用共享 IFLYTEK_APPID / IFLYTEK_API_KEY / IFLYTEK_API_SECRET。
SPARKWEAVE_FORMULA_OCR_PROVIDER=iflytek
IFLYTEK_FORMULA_URL=https://rest-api.xfyun.cn/v2/itr
IFLYTEK_FORMULA_APPID=
IFLYTEK_FORMULA_API_KEY=
IFLYTEK_FORMULA_API_SECRET=
IFLYTEK_FORMULA_ENT=teach-photo-print
IFLYTEK_FORMULA_AUE=raw
IFLYTEK_FORMULA_TIMEOUT=30

# --------------------------------------------
# 讯飞图片理解（可选，多模态题图 / 板书 / 截图）
# --------------------------------------------
# 文档：https://www.xfyun.cn/doc/spark/ImageUnderstanding.html
# 可复用共享 IFLYTEK_APPID / IFLYTEK_API_KEY / IFLYTEK_API_SECRET。
SPARKWEAVE_IMAGE_UNDERSTANDING_PROVIDER=iflytek
IFLYTEK_VISION_PROTOCOL=spark_image
IFLYTEK_VISION_URL=wss://spark-api.cn-huabei-1.xf-yun.com/v2.1/image
IFLYTEK_VISION_APPID=
IFLYTEK_VISION_API_KEY=
IFLYTEK_VISION_API_SECRET=
IFLYTEK_VISION_DOMAIN=imagev3
IFLYTEK_VISION_MAX_TOKENS=2048
IFLYTEK_VISION_TEMPERATURE=0.2
IFLYTEK_VISION_TOP_K=4
IFLYTEK_VISION_TIMEOUT=45
IFLYTEK_VISION_UID=sparkweave

# --------------------------------------------
# 讯飞星辰工作流（可选）
# --------------------------------------------
# 用于把讯飞星辰 Agent 平台发布的工作流接入 SparkWeave 工具层。
# 适合比赛演示：课程资源生成、PPT 大纲、学习诊断、口语练习 Rubric 等。
# 文档：https://www.xfyun.cn/doc/spark/Agent04-API接入.html
IFLYTEK_WORKFLOW_URL=https://xingchen-api.xf-yun.com/workflow/v1/chat/completions
IFLYTEK_WORKFLOW_API_KEY=
IFLYTEK_WORKFLOW_API_SECRET=
IFLYTEK_WORKFLOW_FLOW_ID=
IFLYTEK_WORKFLOW_INPUT_KEY=AGENT_USER_INPUT
IFLYTEK_WORKFLOW_TIMEOUT=60
IFLYTEK_WORKFLOW_UID=sparkweave

# --------------------------------------------
# 讯飞离线替补（默认启用，比赛演示兜底）
# --------------------------------------------
# 1/true：讯飞密钥、网络或权限不可用时，继续返回带 fallback 标记的本地替补结果。
# 0/off：严格依赖真实讯飞服务，服务不可用时直接报错。
SPARKWEAVE_IFLYTEK_OFFLINE_FALLBACK=1
# 可选：离线 ASR 替补时返回的固定转写文本，留空则返回明确的占位提示。
SPARKWEAVE_OFFLINE_ASR_TEXT=

# --------------------------------------------
# 安全 / 网络（可选）
# --------------------------------------------
# 生产环境请保持 false
DISABLE_SSL_VERIFY=false
